# --- secrets / runtime data ---
.env
.env.*
!.env.example

# --- chatterbot data dir ---
# Keep the directory itself but ignore anything inside it (DB, demo data,
# logs). A .gitkeep can be added if you want the dir tracked.
data/*
!data/.gitkeep
# Source-controlled template. Streamers copy to data/streamer_facts.md
# (gitignored) and edit with their own channel-specific context.
!data/streamer_facts.example.md

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Distribution / packaging
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtualenvs
.venv/
.venv-win/
venv/
env/
ENV/
env.bak/
venv.bak/

# uv
.uv/
# uv.lock IS committed for reproducible installs (this is an app, not a library)

