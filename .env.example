# --- Twitch ---
TWITCH_BOT_NICK=
TWITCH_OAUTH_TOKEN=
TWITCH_CHANNEL=
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# --- Ollama ---
OLLAMA_HOST=192.168.69.229
OLLAMA_PORT=11434
OLLAMA_MODEL=qwen3.5:9b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_EMBED_DIM=768

# --- StreamElements ---
STREAMELEMENTS_ENABLED=true
STREAMELEMENTS_JWT=
STREAMELEMENTS_CHANNEL_ID=

# --- Dashboard (web UI) ---
#
# DASHBOARD_HOST controls who can reach the dashboard:
#   127.0.0.1    only this machine (default — safest)
#   0.0.0.0      every interface, i.e. reachable from anywhere on your LAN
#                AND any other interface this host has. ALWAYS pair this with
#                BASIC_AUTH_USER + BASIC_AUTH_PASS below — the dashboard
#                contains chat history, profiles, and (if enabled) moderation
#                incidents. The bot logs a warning at startup if you bind to
#                non-loopback without auth set.
#
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8765

# Optional basic auth. Required if DASHBOARD_HOST != 127.0.0.1. Leaving both
# blank disables auth (fine for loopback-only).
DASHBOARD_BASIC_AUTH_USER=
DASHBOARD_BASIC_AUTH_PASS=

# --- Remote access notes ---
#
# Linux:  set DASHBOARD_HOST=0.0.0.0, set the basic-auth pair above, then
#         allow the port if your distro ships a firewall:
#           ufw:        sudo ufw allow 8765/tcp
#           firewalld:  sudo firewall-cmd --permanent --add-port=8765/tcp \
#                       && sudo firewall-cmd --reload
#         Find the host's LAN IP with `hostname -I`. Browse to
#         http://<that-ip>:8765 from any device on the same network.
#
# WSL2:   binding to 0.0.0.0 inside WSL is NOT reachable from your LAN by
#         default (NAT). Two options:
#           - Mirrored networking (Win 11 22H2+, recommended). In
#             %USERPROFILE%\.wslconfig set:
#               [wsl2]
#               networkingMode=mirrored
#             then `wsl --shutdown`. After that, WSL services on 0.0.0.0
#             show up at the Windows host's LAN IP.
#           - Or run a Windows portproxy + firewall rule (admin PowerShell):
#               netsh interface portproxy add v4tov4 listenport=8765 \
#                 listenaddress=0.0.0.0 connectport=8765 \
#                 connectaddress=$(wsl hostname -I).Trim()
#               netsh advfirewall firewall add rule name="chatterbot 8765" \
#                 dir=in action=allow protocol=TCP localport=8765
#
# Beyond LAN: install Tailscale on the host. Other devices on your tailnet
#         can then hit http://<tailscale-name>:8765 with the same basic auth
#         in front, no router config or DNS or TLS needed.

# --- Storage ---
DB_PATH=data/chatters.db

# --- Summarizer cadence (starting points; tune via observation) ---
# Trigger summarization once a user has this many messages past the watermark
SUMMARIZE_AFTER_MESSAGES=20
# Or after this many minutes of no new messages, whichever comes first
SUMMARIZE_IDLE_MINUTES=10
# How often the idle-sweep loop runs (seconds)
IDLE_SWEEP_INTERVAL_SECONDS=60

# --- Channel topic snapshots ---
TOPICS_INTERVAL_MINUTES=5
TOPICS_MAX_MESSAGES=200

# --- Moderation mode (opt-in, advisory only — never auto-actions) ---
# When true, the bot batches recent messages through a strict-rubric LLM
# classifier and persists flagged messages as incidents in a Moderation tab
# for streamer review. Off by default.
MOD_MODE_ENABLED=false
MOD_REVIEW_INTERVAL_MINUTES=5
MOD_REVIEW_MAX_MESSAGES=100

# --- Run mode (used by container entrypoint) ---
# bot | tui | dashboard
RUN_MODE=bot
